# Backend API (for /api/auth/me and future endpoints)
VITE_API_URL=http://localhost:4000

# Supabase (Auth) - fill these in when you connect a real project
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Demo auth mode: when true and Supabase is not configured,
# the app will let you log in with any email/password as a demo user.
VITE_DEMO_AUTH=true
